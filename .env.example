# Sign up / login and routines are stored in the browser (localStorage).
# No backend or MongoDB is required for auth.

# Optional: if you run `node server.js` for legacy API routes, set MongoDB:
# MONGODB_URI=mongodb://localhost:27017/AI_timetable
# MONGODB_DB_NAME=AI_timetable

# AI provider (openai | anthropic | gemini) and API key for AIService
# REACT_APP_AI_PROVIDER=openai
# REACT_APP_AI_API_KEY=sk-...
