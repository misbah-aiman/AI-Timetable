# MongoDB connection string (required for the server)
MONGODB_URI=mongodb://localhost:27017/AI_timetable
# Optional: database name (default: AI_timetable)
# MONGODB_DB_NAME=AI_timetable

# When the frontend is deployed separately from the API (e.g. Vercel + Railway),
# set this to your backend URL so signup/login work. Leave unset when using the dev proxy.
# REACT_APP_API_URL=https://your-api.example.com

# AI provider (openai | anthropic | gemini) and API key for AIService
# REACT_APP_AI_PROVIDER=openai
# REACT_APP_AI_API_KEY=sk-...
