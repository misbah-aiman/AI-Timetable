# --- AI daily timetable (required for Generate timetable on the dashboard) ---
# The key is read by `server.js` only — never exposed to the browser.
# Run the API: `npm run server` (or `npm run dev` for API + React together).
# https://platform.openai.com/api-keys
#
# Use either name (server checks both):
OPENAI_API_KEY=sk-...
# REACT_APP_AI_API_KEY=sk-...   # legacy CRA name; still supported on the server
#
# Optional override (default is gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: email/password signup + MongoDB (otherwise local-only auth in the browser)
# MONGODB_URI=mongodb://localhost:27017/AI_timetable
# MONGODB_DB_NAME=AI_timetable

# Optional: if the React app is not proxied to the API (e.g. custom deploy), set the API origin:
# REACT_APP_API_URL=http://localhost:5000
